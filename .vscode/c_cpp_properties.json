{
  "version": 4,
  "configurations": [
    {
      "name": "Linux",
      "compilerPath": "/usr/bin/g++",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "intelliSenseMode": "linux-gcc-x64",
      "includePath": [
        "${workspaceFolder}/code/Inc",
        "${workspaceFolder}/code/**",
        "${workspaceFolder}/packages/**/include"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/code",
          "${workspaceFolder}/packages"
        ],
        "limitSymbolsToIncludedHeaders": true
      },
      "defines": []
    }
  ]
}
